# Copy to .env. Default ./ovpn works when docker compose is run from the repo root.
# On Windows, use an absolute path if bind mounts mis-resolve: OVPN_HOST_PATH=E:/FB/protonusa/ovpn
OVPN_HOST_PATH=./ovpn

# OpenVPN provider username/password (optional). When set, the gateway merges them into config; also used as
# fallback for auth-user-pass when no provider auth.txt is found (see README — VPN provider folders).
# for worker auth (auth-user-pass). Do not commit real credentials to git.
# OPENVPN_USERNAME=
# OPENVPN_PASSWORD=

# Optional: override Redis for gateway assignment state (Compose sets REDIS_URL on the gateway service by default).
# REDIS_URL=redis://redis:6379/0
# REDIS_STATE_KEY=portico:assignments-state
# Mirror JSON file whenever Redis is used (backup on host):
# REDIS_ASSIGNMENTS_MIRROR_FILE=1

# --- Optional: published proxy TCP ranges (must match gateway `ports` in docker-compose.yml) ---
# Host side: what LAN/VPS clients connect to. Width (LAST - FIRST + 1) must equal the container range width.
# DOCKER_PROXY_HOST_PORT_FIRST=58000
# DOCKER_PROXY_HOST_PORT_LAST=58515
# Container side: must align with portBase and location count in openvpn-proxy-config.json
# (first listener = portBase; last = portBase + location_count - 1 <= CONTAINER_PORT_LAST).
# DOCKER_PROXY_CONTAINER_PORT_FIRST=50000
# DOCKER_PROXY_CONTAINER_PORT_LAST=50515
# Dashboard/gateway hint for host URLs (normally same as DOCKER_PROXY_HOST_PORT_FIRST).
# PUBLISHED_PROXY_PORT_BASE=58000
